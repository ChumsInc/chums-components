{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "rootDir": "./src",
    "outDir": "./dist"
  },
  "include": [
    "./src/**/*",
    "vite-env.d.ts"
  ],
  "exclude": [
    "./src/**/*.test.tsx",
    "./src/**/*.test.ts",
    "__tests__/**/*"
  ]
}
