{
  "name": "@chumsinc/ui",
  "version": "3.0.0-alpha.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "development": "./src/*.ts",
      "import": "./dist/*.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build:tsc": "tsc -p tsconfig.build.json",
    "build:vite": "vite build",
    "build": "npm run clean && npm run build:vite && npm run build:tsc"
  },
  "peerDependencies": {
    "bootstrap": "^5.3.0",
    "classnames": "*",
    "react": "^19.2.7",
    "react-bootstrap": "^2.10.10",
    "react-dom": "19.2.7"
  }
}
