{
  "name": "@chumsinc/ui",
  "version": "3.0.4-beta.2",
  "description": "Chums Common Components",
  "scripts": {
    "dev": "vite",
    "clean": "rimraf dist",
    "build": "npm run clean && vite build && tsc --project tsconfig.build.json",
    "test": "vitest run",
    "test-verbose": "vitest run --reporter=verbose",
    "test-config": "npm run test-vitest-config.js"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChumsInc/chums-components.git"
  },
  "author": "Steve Montgomery",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ChumsInc/chums-components/issues"
  },
  "homepage": "https://github.com/ChumsInc/chums-components#readme",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "development": "./src/index.ts"
    },
    "./AppVersion": {
      "types": "./dist/app-version/index.d.ts",
      "import": "./dist/app-version/index.js",
      "development": "./src/app-version/index.ts"
    },
    "./CustomerAutocomplete": {
      "types": "./dist/customer-autocomplete/index.d.ts",
      "import": "./dist/customer-autocomplete/index.js",
      "development": "./src/customer-autocomplete/index.ts"
    },
    "./ItemAutocomplete": {
      "types": "./dist/item-autocomplete/index.d.ts",
      "import": "./dist/item-autocomplete/index.js",
      "development": "./src/item-autocomplete/index.ts"
    },
    "./dist/*.css": "./dist/*.css"
  },
  "devDependencies": {
    "@base-ui/react": "^1.6.0",
    "@chumsinc/ui-utils": "^2.1.8",
    "@emotion/styled": "^11.14.1",
    "@eslint/js": "^10.0.1",
    "@mantine/hooks": "^9.4.1",
    "@microsoft/api-extractor": "^7.58.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "auto-changelog": "^2.4.0",
    "bootstrap": "^5.1.3",
    "bootstrap-icons": "^1.4.0",
    "chums-types": "github:ChumsInc/chums-types",
    "classnames": "*",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "glob": "^13.0.6",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.1.0",
    "vite": "^8.1.1",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.6.0",
    "@chumsinc/ui-utils": "^2.1.8",
    "@emotion/styled": "^11.14.1",
    "@mantine/hooks": "^9.4.1",
    "classnames": "*",
    "react": ">=18.1.0",
    "react-bootstrap": "^2.10.10",
    "react-dom": ">=18.1.0"
  },
  "peerDependenciesMeta": {
    "@base-ui/react": {
      "optional": true
    },
    "@mantine/hooks": {
      "optional": true
    }
  },
  "auto-changelog": {
    "template": "changelog-template.hbs",
    "unreleased": true,
    "commitLimit": false,
    "breakingPattern": "BREAKING CHANGE:"
  }
}
